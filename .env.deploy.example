# ── Deploy de teste (docker-compose.deploy.yml) ───────────────────────────────
# Copie para `.env` no host e ajuste os valores. NÃO versione o .env real.
#
# sslip.io: troque <IP> pelo IP público do host usando TRAÇOS (ex.: 203-0-113-5).
# Pode usar pontos também (203.0.113.5.sslip.io); traços evitam ambiguidades.

# Hostnames públicos (sslip.io) e URLs
APP_HOST=<IP>.sslip.io
API_HOST=api.<IP>.sslip.io
APP_PUBLIC_URL=https://<IP>.sslip.io
# API_PUBLIC_URL é usada tanto p/ rotear quanto no build do frontend (assada na imagem)
API_PUBLIC_URL=https://api.<IP>.sslip.io
ACME_EMAIL=voce@exemplo.com

# Login social (opcional p/ teste)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=demo-client-id

# Postgres
POSTGRES_DB=horafy
POSTGRES_USER=horafy
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# Redis
REDIS_PASSWORD=troque-por-uma-senha-redis

# RabbitMQ
RABBITMQ_USER=horafy
RABBITMQ_PASSWORD=troque-por-uma-senha-rabbit
RABBITMQ_VHOST=horafy

# JWT (mínimo 32 caracteres)
JWT_SECRET=troque-por-um-segredo-de-no-minimo-32-chars
