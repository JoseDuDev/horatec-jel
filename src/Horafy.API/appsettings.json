{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=horafy;Username=horafy;Password=horafy_dev_pass;Search Path=public"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "Properties": {
      "Application": "Horafy.API"
    }
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173"
  ],
  "Jwt": {
    "Issuer": "horafy",
    "Audience": "horafy-clients",
    "ExpirationMinutes": 60
  },
  "Platform": {
    "Domain": "horafy.com.br"
  },
  "MercadoPago": {
    "AccessToken": "",
    "WebhookSecret": "",
    "NotificationUrl": ""
  },
  "RabbitMq": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "EvolutionApi": {
    "BaseUrl": "",
    "ApiKey": "",
    "InstanceName": "horafy"
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "no-reply@horafy.com.br",
    "FromName": "Horafy",
    "UseSsl": true
  }
}
