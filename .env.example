# ── Horafy — variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores antes de rodar docker-compose

# PostgreSQL
POSTGRES_PASSWORD=horafy_dev_pass

# Redis
REDIS_PASSWORD=horafy_redis_pass

# RabbitMQ
RABBITMQ_PASSWORD=horafy_rabbit_pass

# JWT (gere uma chave segura com: openssl rand -base64 64)
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SEGURA_DE_64_CARACTERES_MINIMO

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# WhatsApp (Evolution API)
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
